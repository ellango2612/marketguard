# ── MarketGuard Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in values before running locally.

# Server
HTTP_PORT=8080
GRPC_PORT=9090
WORKERS=48

# PostgreSQL
POSTGRES_DSN=postgres://marketguard:password@localhost:5432/marketguard?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Kafka
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC_TX=transactions
KAFKA_TOPIC_ALERTS=alerts

# Auth — CHANGE THIS in production
JWT_SECRET=change-me-in-production-use-32-char-random-string

# AWS (for EC2 / ECS deployment)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
